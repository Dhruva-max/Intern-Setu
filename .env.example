# Frontend (Next.js)
NEXT_PUBLIC_AIRTABLE_EMBED_URL="https://airtable.com/embed/xxxxx"
NEXT_PUBLIC_BOTPRESS_URL="https://your-botpress-host"
NEXT_PUBLIC_RECOMMEND_URL="http://localhost:5000"

# Backend (Flask)
